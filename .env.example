# ─────────────────────────────────────────────────────────────
# ROOTMAN MONEY ROUTE — Environment Variables
# Copy this file to `.env.local` for local dev, and add the same
# keys in Vercel → Project Settings → Environment Variables.
#
# The MVP runs fully WITHOUT any of these set. They are only needed
# once Supabase / payments are integrated in later phases.
# ─────────────────────────────────────────────────────────────

# Public site URL (used for absolute links / metadata). Optional.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase (Phase 2 — persistence & auth).
# App works without these; set them to enable saving sessions/snapshots.
# Get from Supabase → Project Settings → API.
#   NEXT_PUBLIC_*  : safe to expose to the browser
#   SERVICE_ROLE   : SERVER ONLY — never expose. Used for trusted writes.
# NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>
# SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# Payments (Phase 3 — Stripe / PromptPay). Leave blank until integrated.
# App works without these; checkout returns 503 when STRIPE_SECRET_KEY is absent.
# Get keys from Stripe → Developers → API keys.
# STRIPE_SECRET_KEY : SERVER ONLY (sk_live_... / sk_test_...)
# STRIPE_WEBHOOK_SECRET : from the webhook endpoint you create
#   (Developers → Webhooks → https://<your-domain>/api/payments/webhook,
#    listening to `checkout.session.completed`). Format: whsec_...
# Enable PromptPay in Stripe → Settings → Payment methods (Thai account, THB).
# Checkout auto-shows every enabled method — no code change needed.
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
